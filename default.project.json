      "$className": "Workspace",
      "SunsetIsland": {
        "$path": "src/workspace/SunsetIsland.model.json"
      }
    },
    "Lighting": {
      "$className": "Lighting",
      "$properties": {
        "ClockTime": 17.8,
        "Brightness": 2.2,
        "EnvironmentDiffuseScale": 0.65,
        "EnvironmentSpecularScale": 0.45,
        "OutdoorAmbient": [1, 0.7450980392156863, 0.5490196078431373],
        "FogColor": [1, 0.6980392156862745, 0.5019607843137255],
        "FogStart": 120,
        "FogEnd": 520
      }
    },
    "ReplicatedStorage": {
      "$className": "ReplicatedStorage",
